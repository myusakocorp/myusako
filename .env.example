# USAKO Intranet Environment Variables
# Copy this file to .env and fill in your values

# --- AI Phone Agent Brain ---
PERPLEXITY_API_KEY=pplx-your-key-here

# --- Twilio Telephony (required for IVR + incoming calls) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Twilio Softphone (required for browser-based VoIP) ---
# Create an API Key at https://console.twilio.com/us1/account/keys-credentials/api-keys
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your-api-secret-here
# Create a TwiML App at https://console.twilio.com/us1/develop/voice/manage/twiml-apps
# Set the Voice URL to https://your-domain/api/twilio/outbound
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Production Settings ---
NODE_ENV=production
SESSION_SECRET=generate-a-random-string-here
PORT=3000
