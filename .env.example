# PERPLEXITY_API_KEY: Required for Perplexity AI phone agent brain.
# Get your API key from https://docs.perplexity.ai/ (Settings > API Keys)
PERPLEXITY_API_KEY="YOUR_PERPLEXITY_API_KEY"

# GEMINI_API_KEY: Required for AI route generation (Rover daily routes).
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# TWILIO_ACCOUNT_SID: Your Twilio Account SID
TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN: Your Twilio Auth Token
TWILIO_AUTH_TOKEN=
# TWILIO_API_KEY: Created in Twilio Console (Standard API Key)
TWILIO_API_KEY=
# TWILIO_API_SECRET: Secret for the API Key
TWILIO_API_SECRET=
# TWILIO_TWIML_APP_SID: SID of the TwiML App for the softphone
TWILIO_TWIML_APP_SID=
# TWILIO_PHONE_NUMBER: Your Twilio phone number (e.g., +1234567890)
TWILIO_PHONE_NUMBER=

# EMAIL_USER: Your full email address (e.g., user@myusako.org)
EMAIL_USER=
# EMAIL_PASS: Your Private Email password
EMAIL_PASS=
